{
  "name": "temp-vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/auto-update.js && concurrently --names \"vite,mcp,backend\" --prefix-colors \"cyan,green,magenta\" \"vite\" \"npm --prefix mcp-server start\" \"node scripts/start-backend.cjs\"",
    "mcp": "npm --prefix mcp-server start",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/generate-sitemap.js && node scripts/prerender.js",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@pdfsmaller/pdf-encrypt": "^1.0.2",
    "@types/jsbarcode": "^3.11.4",
    "@types/papaparse": "^5.5.2",
    "alasql": "^4.17.3",
    "exifr": "^7.1.3",
    "jsbarcode": "^3.12.3",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "konva": "^10.3.0",
    "lucide-react": "^1.21.0",
    "papaparse": "^5.5.4",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-konva": "^19.2.5",
    "react-router-dom": "^7.18.0",
    "tesseract.js": "^7.0.0",
    "use-image": "^1.1.4"
