# DomoDomo MCP Server — security configuration
# Copy to .env (gitignored) and adjust. All values are optional; secure defaults apply.

# Interface to bind. Keep loopback — this server exposes shell/file/desktop tools
# and must never be reachable from the LAN.
MCP_HOST=127.0.0.1

# Port (default 3001).
MCP_PORT=3001

# Comma-separated CORS allow-list. Only these browser origins may connect.
MCP_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Shared secret. When set, ALL /sse and /message requests must supply it via
# ?token=<value> (EventSource) or Authorization: Bearer / x-mcp-token header.
# In the web app, store the SAME value under localStorage key: domodomo_mcp_token
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MCP_AUTH_TOKEN=
